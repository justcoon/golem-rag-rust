# =============================================================================
# Golem RAG System Environment Configuration
# =============================================================================
# Copy this file to .env and modify values as needed
# This file works with: Docker Compose, Shell Scripts, and Rust Applications

# =============================================================================
# PostgreSQL Configuration
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_DB=golem_rag
POSTGRES_USER=golem_user
POSTGRES_PASSWORD=golem_password
POSTGRES_PORT=5432
# Database URL for agents and applications
DB_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# =============================================================================
# RustFS S3 Configuration
# =============================================================================
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin123
RUSTFS_REGION=us-east-1
RUSTFS_BUCKET=golem-documents
RUSTFS_PORT=9000
RUSTFS_ADDR=0.0.0.0:9000
RUSTFS_LOG_LEVEL=info
# S3-compatible variables for applications
AWS_ACCESS_KEY_ID=${RUSTFS_ACCESS_KEY}
AWS_SECRET_ACCESS_KEY=${RUSTFS_SECRET_KEY}
AWS_DEFAULT_REGION=${RUSTFS_REGION}
AWS_S3_BUCKET=${RUSTFS_BUCKET}
S3_ENDPOINT_URL=http://localhost:${RUSTFS_PORT}

# =============================================================================
# Ollama Configuration
# =============================================================================
OLLAMA_PORT=11434
OLLAMA_HOST=0.0.0.0
OLLAMA_MODEL=nomic-embed-text
# Ollama variables for applications
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=${OLLAMA_MODEL}
EMBEDDING_API_BASE=http://localhost:${OLLAMA_PORT}
EMBEDDING_API_KEY=ollama

# =============================================================================
# Application Configuration
# =============================================================================
RUST_LOG=info
DATA_DIR=data

# =============================================================================
# Docker Configuration
# =============================================================================
# Note: Network name is static in docker-compose.yml (golem-rag-network)

# =============================================================================
# Usage Instructions:
# =============================================================================
# 1. Copy to .env: cp .env.example .env
# 2. Modify values as needed
# 3. Use with docker-compose: docker-compose up
# 4. Use with scripts: ./upload_to_s3.sh
# 5. Use in Rust apps: load with dotenv crate
